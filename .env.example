# SafeSurveil local environment template.
# Keep real values only in .env. Never commit API keys, passwords, bearer
# tokens, BV-BRC token files, downloaded raw data, or tool run logs.

# Core runtime
APP_ENV=local
ARTIFACT_ROOT=artifacts
SQLITE_DB_PATH=data/safesurveil.sqlite
DATASET_ROOT=data
LOG_LEVEL=INFO
DEMO_MODE=false
USE_FIXTURES=false

# Phase 6B live data integrations
# NCBI_API_KEY is used for NCBI Datasets requests when available.
NCBI_API_KEY=
NCBI_DATASETS_BASE_URL=https://api.ncbi.nlm.nih.gov/datasets/v2
NCBI_PATHOGEN_DETECTION_BASE_URL=https://ftp.ncbi.nlm.nih.gov/pathogen
LIVE_HTTP_TIMEOUT_SECONDS=30
LIVE_HTTP_RETRY_COUNT=2

# Phase 7 LLM integration, intentionally not wired during Phase 6B.
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=google/gemma-4-31b-it:free
LLM_FALLBACK_MODEL=inclusionai/ling-2.6-flash:free
LLM_REASONING_ENABLED=true
LLM_MOCK_MODE=false

# Phase 8 Thesys C1 integration. Keep the API key backend-side.
THESYS_API_KEY=
THESYS_BASE_URL=https://api.thesys.dev/v1/embed
THESYS_MODEL=c1/anthropic/claude-sonnet-4/v-20251230

# BV-BRC live data integration.
# The token path points to a local ignored file; do not commit token contents.
BV_BRC_USERNAME=
BV_BRC_USERNAME_ALT=
BV_BRC_PASSWORD=
BV_BRC_AUTH_URL=https://user.patricbrc.org/authenticate
BV_BRC_API_BASE_URL=https://www.patricbrc.org/api
BV_BRC_TOKEN_PATH=~/.patric_token

# Optional local tool overrides. If unset, Phase 6B implementations should use PATH.
AMRFINDERPLUS_BIN=
AMRFINDERPLUS_DB=
MASH_BIN=
